{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "contact": {
    "homepage": "${mod_homepage}",
    "sources": "${mod_github}"
  },
  "accessWidener": "${mod_id}.accesswidener",
  "license": "${mod_license}",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "net.mehvahdjukaar.codecui.platform.CodecUIFabric"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json",
    "${mod_id}-common.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17",
    "fabric": ">=0.116.0+1.21.1",
    "minecraft": "=${minecraft_version}"
  }
}
